# ---- Security: never commit credentials ----
.env
*.env
.netrc
credentials.yaml
secrets.yaml
*.key
*.token
*.pem

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
wheels/
release/

# ---- uv / virtualenv ----
.venv/
venv/
.uv-cache/
uv.lock.bak

# ---- PyInstaller / packaging artifacts ----
*.spec
*.manifest
pyinstaller-build/
smoke_package/
*.exe

# ---- Test / lint / type caches ----
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tmp*/
.tmp_*
.ui_preview*/
_shots/

# ---- OS / editor / agent-local state ----
.DS_Store
Thumbs.db
.idea/
.vscode/
.codex/
.cursor/
.agents/

# ---- InSAR data: never commit user data or downloaded products ----
*.SAFE
*.SAFE/
*.zip
*.tif
*.tiff
*.dem
*.SLC
*.tar
*.tar.gz
*.tgz
*.7z
*.rar
*.hgt
*.img
*.grd
*.nc
*.h5
*.hdf5
*.he5
*.vrt

# ---- Local study material / private docs / bulky cached data ----
参考项目/
sentinel2/
边界/
docs/soft_copyright/
insarassistantreal_test/
insar_realtest_package/
