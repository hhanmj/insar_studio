# ---- Security: never commit credentials ----
.env
*.env
.netrc
credentials.yaml
secrets.yaml
*.key
*.token

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
wheels/

# ---- uv / virtualenv ----
.venv/
venv/
uv.lock.bak

# ---- PyInstaller / packaging artifacts (Task 022 onward) ----
# build/ and dist/ are already ignored above; *.exe is ignored below.
*.spec
*.manifest
pyinstaller-build/

# ---- Windows exe smoke-test package (Task 023; generated locally) ----
smoke_package/

# ---- Test / lint / type caches ----
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# ---- OS / editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/

# ---- InSAR data (must never be committed) ----
*.SAFE
*.SAFE/
*.zip
*.tif
*.tiff
*.dem
*.SLC
# Bulk archives (e.g. GACOS .tar.gz downloads, DEM tiles)
*.tar
*.tar.gz
*.tgz
*.7z
*.rar
# Other large remote-sensing raster / data formats
*.hgt
*.img
*.grd
*.nc
*.h5
*.hdf5
*.he5
*.vrt
# Note: small *.ztd / *.ztd.rsc GACOS fixtures under tests/ are intentionally
# tracked and must NOT be ignored.

# ---- Third-party reference projects (study only, do not commit) ----
参考项目/
*.exe
